<?xml version="1.0" encoding="utf-8"?>
<!--
  Rutas que el FileProvider (${applicationId}.mscnprovider) puede compartir.
  Application.temporaryCachePath en Android = getCacheDir() (interno); incluimos
  external por las dudas.
-->
<paths>
    <cache-path name="cache" path="." />
    <files-path name="files" path="." />
    <external-cache-path name="ext_cache" path="." />
    <external-files-path name="ext_files" path="." />
</paths>
